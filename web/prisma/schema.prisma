generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatusMatricula {
  PENDENTE
  EM_ANALISE
  AGUARDANDO_DOCUMENTOS
  AGUARDANDO_PAGAMENTO
  ATIVA
  CANCELADA
  CONCLUIDA
}

enum StatusConviteMatricula {
  AGUARDANDO_ENVIO
  AGUARDANDO_RESPONSAVEL
  EM_PREENCHIMENTO
  PREENCHIDO
  CONCLUIDO
  EXPIRADO
  CANCELADO
}

enum TipoDocumentoMatricula {
  CERTIDAO_NASCIMENTO
  RG_ALUNO
  CPF_ALUNO
  RG_RESPONSAVEL
  CPF_RESPONSAVEL
  COMPROVANTE_RESIDENCIA
  CARTEIRA_VACINACAO
  FOTO_ALUNO
  LAUDO_MEDICO
  CONTRATO_ASSINADO
  COMPROVANTE_PAGAMENTO
  OUTRO
}

enum StatusDocumentoMatricula {
  PENDENTE
  ENVIADO
  EM_ANALISE
  APROVADO
  REJEITADO
  REENVIO_SOLICITADO
  CANCELADO
}

enum StatusPagamentoMatricula {
  PENDENTE
  EM_ANALISE
  CONFIRMADO
  CANCELADO
}

enum FormaPagamentoMatricula {
  PIX
  CARTAO
  BOLETO
  DINHEIRO
  TRANSFERENCIA
  OUTRO
}

enum StatusTarefa {
  A_FAZER
  EM_ANDAMENTO
  AGUARDANDO
  CONCLUIDA
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum TipoOcorrenciaAluno {
  ADVERTENCIA
  SUSPENSAO
  OCORRENCIA
  RELATORIO
  RESUMO
  ATENDIMENTO
}

enum StatusOcorrenciaAluno {
  RASCUNHO
  REGISTRADO
  ENVIADO
  CANCELADO
}

enum TipoComunicado {
  SIMPLES
  CIENCIA
  EVENTO
  AUTORIZACAO
  PAGAMENTO
}

enum StatusComunicado {
  RASCUNHO
  PREPARADO
  ENVIADO
  CANCELADO
  ARQUIVADO
}

enum StatusDestinatarioComunicado {
  PENDENTE
  ENVIADO
  VISUALIZADO
  RESPONDIDO
  CANCELADO
}

enum TipoRespostaComunicado {
  CIENTE
  PARTICIPA
  NAO_PARTICIPA
  AUTORIZADO
  NAO_AUTORIZADO
  RESPOSTA_TEXTO
}

enum PapelUsuario {
  ADMINISTRADOR
  SECRETARIA
  COORDENACAO
  FINANCEIRO
  RESPONSAVEL
}

enum StatusUsuario {
  PENDENTE
  ATIVO
  BLOQUEADO
}

enum StatusConviteAcesso {
  PENDENTE
  UTILIZADO
  CANCELADO
  EXPIRADO
}

enum TipoEmailTransacional {
  CONVITE_ACESSO
  RECUPERACAO_SENHA
  CONFIRMACAO_CONTA
  COMUNICADO
  AVISO_DOCUMENTO
  ATUALIZACAO_MATRICULA
  CRM
}

enum StatusEmailTransacional {
  PENDENTE
  ENVIADO
  FALHOU
  NAO_CONFIGURADO
}

model Escola {
  id           String   @id @default(cuid())
  nome         String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  responsaveis Responsavel[]
  alunos       Aluno[]
  turmas       Turma[]
  matriculas   Matricula[]
  tarefas      Tarefa[]
  ocorrencias  OcorrenciaAluno[]

  convitesMatricula   ConviteMatricula[]
  documentosMatricula DocumentoMatricula[]
  pagamentosMatricula PagamentoMatricula[]

  comunicados              Comunicado[]
  destinatariosComunicados DestinatarioComunicado[]
  respostasComunicados     RespostaComunicado[]

  usuarios            Usuario[]
  convitesAcesso      ConviteAcesso[]
  recuperacoesSenha   RecuperacaoSenha[]
  tentativasLogin     TentativaLogin[]
  registrosAuditoria  RegistroAuditoria[]
  emailsTransacionais EmailTransacional[]
}

model Responsavel {
  id           String   @id @default(cuid())
  nome         String
  cpf          String?  @unique
  email        String?
  telefone     String
  profissao    String?
  endereco     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id])

  alunos Aluno[]

  destinatariosComunicados DestinatarioComunicado[]
  respostasComunicados     RespostaComunicado[]

  usuario        Usuario?
  convitesAcesso ConviteAcesso[]
}

model Turma {
  id           String   @id @default(cuid())
  nome         String
  segmento     String
  turno        String
  capacidade   Int
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id])

  alunos            Aluno[]
  comunicados       Comunicado[]
  convitesMatricula ConviteMatricula[]
}

model Aluno {
  id                 String   @id @default(cuid())
  nome               String
  dataNascimento     DateTime
  sexo               String?
  cpf                String?
  certidaoNascimento String?
  alergias           String?
  observacoes        String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  escolaId      String
  responsavelId String
  turmaId       String?

  escola      Escola      @relation(fields: [escolaId], references: [id])
  responsavel Responsavel @relation(fields: [responsavelId], references: [id])
  turma       Turma?      @relation(fields: [turmaId], references: [id])

  matriculas  Matricula[]
  tarefas     Tarefa[]
  ocorrencias OcorrenciaAluno[]

  comunicados              Comunicado[]
  destinatariosComunicados DestinatarioComunicado[]
  respostasComunicados     RespostaComunicado[]

  convitesAcesso ConviteAcesso[]
}

model Matricula {
  id            String          @id @default(cuid())
  anoLetivo     Int
  dataMatricula DateTime        @default(now())
  status        StatusMatricula @default(PENDENTE)
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt

  escolaId String
  alunoId  String

  escola Escola @relation(fields: [escolaId], references: [id])
  aluno  Aluno  @relation(fields: [alunoId], references: [id])

  tarefas    Tarefa[]
  documentos DocumentoMatricula[]

  pagamentoMatricula PagamentoMatricula?

  conviteMatricula ConviteMatricula?

  convitesAcesso ConviteAcesso[]
}

model ConviteMatricula {
  id    String @id @default(cuid())
  token String @unique

  status StatusConviteMatricula @default(AGUARDANDO_ENVIO)

  nomeAluno           String
  nomeResponsavel     String
  telefoneResponsavel String
  emailResponsavel    String?

  anoLetivo Int

  expiraEm DateTime

  enviadoEm     DateTime?
  visualizadoEm DateTime?
  preenchidoEm  DateTime?
  concluidoEm   DateTime?
  canceladoEm   DateTime?

  rascunhoDados Json?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId    String
  turmaId     String?
  matriculaId String? @unique

  escola    Escola     @relation(fields: [escolaId], references: [id])
  turma     Turma?     @relation(fields: [turmaId], references: [id])
  matricula Matricula? @relation(fields: [matriculaId], references: [id])

  documentos DocumentoMatricula[]

  @@index([escolaId])
  @@index([turmaId])
  @@index([status])
  @@index([expiraEm])
}

model DocumentoMatricula {
  id String @id @default(cuid())

  tipo   TipoDocumentoMatricula
  status StatusDocumentoMatricula @default(PENDENTE)

  titulo        String
  descricao     String?
  obrigatorio   Boolean @default(true)
  ordemExibicao Int     @default(0)

  nomeArquivoOriginal String?
  nomeArquivoInterno  String?
  urlArquivo          String?
  chaveArmazenamento  String?

  mimeType     String?
  extensao     String?
  tamanhoBytes Int?

  versao Int @default(1)

  observacaoResponsavel String?
  observacaoSecretaria  String?
  motivoRejeicao        String?

  enviadoEm           DateTime?
  analisadoEm         DateTime?
  aprovadoEm          DateTime?
  rejeitadoEm         DateTime?
  reenvioSolicitadoEm DateTime?

  analisadoPor String?
  aprovadoPor  String?
  rejeitadoPor String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId    String
  conviteId   String
  matriculaId String?

  escola    Escola           @relation(fields: [escolaId], references: [id])
  convite   ConviteMatricula @relation(fields: [conviteId], references: [id], onDelete: Cascade)
  matricula Matricula?       @relation(fields: [matriculaId], references: [id], onDelete: SetNull)

  @@index([escolaId])
  @@index([conviteId])
  @@index([matriculaId])
  @@index([status])
  @@index([tipo])
  @@index([conviteId, tipo])
}

model PagamentoMatricula {
  id String @id @default(cuid())

  status StatusPagamentoMatricula @default(PENDENTE)

  descricao     String    @default("Taxa de matrícula")
  valorCentavos Int
  vencimento    DateTime?

  formaPagamento FormaPagamentoMatricula?
  referencia     String?
  observacao     String?

  pagoEm       DateTime?
  confirmadoEm DateTime?
  canceladoEm  DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId    String
  matriculaId String @unique

  escola    Escola    @relation(fields: [escolaId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@index([escolaId])
  @@index([status])
  @@index([vencimento])
}

model Tarefa {
  id           String           @id @default(cuid())
  titulo       String
  descricao    String?
  setor        String
  responsavel  String?
  status       StatusTarefa     @default(A_FAZER)
  prioridade   PrioridadeTarefa @default(MEDIA)
  prazo        DateTime?
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  escolaId    String
  alunoId     String?
  matriculaId String?

  escola    Escola     @relation(fields: [escolaId], references: [id])
  aluno     Aluno?     @relation(fields: [alunoId], references: [id])
  matricula Matricula? @relation(fields: [matriculaId], references: [id])
}

model OcorrenciaAluno {
  id String @id @default(cuid())

  tipo       TipoOcorrenciaAluno
  titulo     String
  descricao  String
  textoFinal String?

  status StatusOcorrenciaAluno @default(REGISTRADO)

  enviarParaResponsavel Boolean   @default(false)
  enviadoPorEmail       Boolean   @default(false)
  emailResponsavel      String?
  dataEnvioEmail        DateTime?

  tokenCiencia          String?   @unique
  cienciaConfirmada     Boolean   @default(false)
  dataCiencia           DateTime?
  nomeConfirmante       String?
  parentescoConfirmante String?
  observacaoCiencia     String?

  inicioSuspensao DateTime?
  fimSuspensao    DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId String
  alunoId  String

  escola Escola @relation(fields: [escolaId], references: [id])
  aluno  Aluno  @relation(fields: [alunoId], references: [id])
}

model Comunicado {
  id String @id @default(cuid())

  tipo   TipoComunicado
  status StatusComunicado @default(RASCUNHO)

  titulo   String
  conteudo String

  publicoAlvo String?
  observacoes String?

  dataEvento    DateTime?
  horaEvento    String?
  localEvento   String?
  valorCentavos Int?

  requerCiencia        Boolean @default(false)
  requerParticipacao   Boolean @default(false)
  requerAutorizacao    Boolean @default(false)
  requerPagamento      Boolean @default(false)
  permiteRespostaTexto Boolean @default(false)

  enviadoEm    DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  escolaId String
  alunoId  String?
  turmaId  String?

  escola Escola @relation(fields: [escolaId], references: [id])
  aluno  Aluno? @relation(fields: [alunoId], references: [id])
  turma  Turma? @relation(fields: [turmaId], references: [id])

  destinatarios DestinatarioComunicado[]
  respostas     RespostaComunicado[]
}

model DestinatarioComunicado {
  id String @id @default(cuid())

  status StatusDestinatarioComunicado @default(PENDENTE)

  nomeResponsavel String?
  email           String?
  telefone        String?

  tokenResposta String? @unique

  enviadoEm     DateTime?
  visualizadoEm DateTime?
  respondidoEm  DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId      String
  comunicadoId  String
  alunoId       String?
  responsavelId String?

  escola      Escola       @relation(fields: [escolaId], references: [id])
  comunicado  Comunicado   @relation(fields: [comunicadoId], references: [id])
  aluno       Aluno?       @relation(fields: [alunoId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])

  respostas RespostaComunicado[]
}

model RespostaComunicado {
  id String @id @default(cuid())

  tipo TipoRespostaComunicado

  cienciaConfirmada Boolean  @default(false)
  participa         Boolean?
  autorizado        Boolean?

  motivoNegativa String?
  observacao     String?

  nomeRespondente       String?
  parentescoRespondente String?

  dataResposta DateTime @default(now())
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  escolaId       String
  comunicadoId   String
  destinatarioId String
  alunoId        String?
  responsavelId  String?

  escola       Escola                 @relation(fields: [escolaId], references: [id])
  comunicado   Comunicado             @relation(fields: [comunicadoId], references: [id])
  destinatario DestinatarioComunicado @relation(fields: [destinatarioId], references: [id])
  aluno        Aluno?                 @relation(fields: [alunoId], references: [id])
  responsavel  Responsavel?           @relation(fields: [responsavelId], references: [id])
}

model Usuario {
  id        String        @id @default(cuid())
  nome      String
  email     String        @unique
  senhaHash String
  papel     PapelUsuario
  status    StatusUsuario @default(PENDENTE)

  ultimoAcessoEm DateTime?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  escolaId      String
  responsavelId String? @unique

  escola      Escola       @relation(fields: [escolaId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])

  sessoes                    SessaoUsuario[]
  convitesCriados            ConviteAcesso[]     @relation("ConviteAcessoCriador")
  convitesAtivados           ConviteAcesso[]     @relation("ConviteAcessoUsuarioAtivado")
  recuperacoesSenha          RecuperacaoSenha[]
  registrosAuditoria         RegistroAuditoria[]
  emailsTransacionaisCriados EmailTransacional[] @relation("EmailTransacionalCriador")

  @@index([escolaId])
  @@index([papel])
  @@index([status])
}

model SessaoUsuario {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  expiraEm    DateTime
  revogadaEm  DateTime?
  ultimoUsoEm DateTime?
  criadoEm    DateTime  @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
  @@index([revogadaEm])
}

model ConviteAcesso {
  id        String              @id @default(cuid())
  tokenHash String              @unique
  status    StatusConviteAcesso @default(PENDENTE)
  expiraEm  DateTime

  utilizadoEm  DateTime?
  canceladoEm  DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  escolaId           String
  responsavelId      String
  alunoId            String?
  matriculaId        String?
  criadoPorUsuarioId String?
  usuarioAtivadoId   String?

  escola         Escola      @relation(fields: [escolaId], references: [id])
  responsavel    Responsavel @relation(fields: [responsavelId], references: [id])
  aluno          Aluno?      @relation(fields: [alunoId], references: [id])
  matricula      Matricula?  @relation(fields: [matriculaId], references: [id])
  criadoPor      Usuario?    @relation("ConviteAcessoCriador", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)
  usuarioAtivado Usuario?    @relation("ConviteAcessoUsuarioAtivado", fields: [usuarioAtivadoId], references: [id], onDelete: SetNull)

  @@index([escolaId])
  @@index([responsavelId])
  @@index([alunoId])
  @@index([matriculaId])
  @@index([status])
  @@index([expiraEm])
}

model RecuperacaoSenha {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiraEm  DateTime

  utilizadoEm DateTime?
  revogadoEm  DateTime?
  criadoEm    DateTime  @default(now())

  escolaId  String
  usuarioId String

  escola  Escola  @relation(fields: [escolaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([escolaId])
  @@index([usuarioId])
  @@index([expiraEm])
}

model TentativaLogin {
  id                String   @id @default(cuid())
  identificadorHash String
  ipHash            String?
  sucesso           Boolean  @default(false)
  bloqueada         Boolean  @default(false)
  criadaEm          DateTime @default(now())

  escolaId String?
  escola   Escola? @relation(fields: [escolaId], references: [id], onDelete: SetNull)

  @@index([identificadorHash, criadaEm])
  @@index([ipHash, criadaEm])
  @@index([escolaId])
}

model RegistroAuditoria {
  id         String   @id @default(cuid())
  acao       String
  resultado  String
  entidade   String?
  entidadeId String?
  metadados  Json?
  criadoEm   DateTime @default(now())

  escolaId  String
  usuarioId String?

  escola  Escola   @relation(fields: [escolaId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([escolaId, criadoEm])
  @@index([usuarioId])
  @@index([acao])
}

model EmailTransacional {
  id                String                  @id @default(cuid())
  tipo              TipoEmailTransacional
  status            StatusEmailTransacional @default(PENDENTE)
  destinatario      String
  assunto           String
  conteudo          String
  provedor          String?
  mensagemExternaId String?
  tentativas        Int                     @default(0)
  erroClasse        String?
  enviadoEm         DateTime?
  criadoEm          DateTime                @default(now())
  atualizadoEm      DateTime                @updatedAt

  escolaId           String
  criadoPorUsuarioId String?

  escola    Escola   @relation(fields: [escolaId], references: [id])
  criadoPor Usuario? @relation("EmailTransacionalCriador", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([escolaId, criadoEm])
  @@index([status])
  @@index([tipo])
}
