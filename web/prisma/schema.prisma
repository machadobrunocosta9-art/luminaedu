generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Aluno {
  id           String   @id @default(uuid())
  nome         String
  turma        String
  responsavel  String
  telefone     String
  status       String   @default("Ativo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}